    "type": "object",

    "properties": {
        "id": {
            "type": "integer"
        },

        "agencia": {
            "type": "string"
        },

        "numero": {
            "type": "string"
        },

        "saldo": {
            "type": "string"
        },

        "ativa": {
            "type": "boolean"
        }
    },

    "required": [
        "id",
        "agencia",
        "numero",
        "saldo",
        "ativa"
    ],

    "additionalProperties": false
}